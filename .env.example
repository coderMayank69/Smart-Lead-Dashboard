# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers → copy the connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart-lead-dashboard?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# For local Docker: http://localhost
# For Render: https://your-client-service.onrender.com
CLIENT_URL=http://localhost
